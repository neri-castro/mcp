# URL base de la instancia Gitea (ej: https://git.tu-empresa.com)
GITEA_BASE_URL=https://gitea.example.com

# Tipo de autenticación: token | native | ldap
GITEA_AUTH_TYPE=token

# --- Configuración según GITEA_AUTH_TYPE ---

# Si usas GITEA_AUTH_TYPE=token (Recomendado)
GITEA_TOKEN=tu_token_personal_de_acceso

# Si usas GITEA_AUTH_TYPE=native
GITEA_USERNAME=nombre_usuario_gitea
GITEA_PASSWORD=tu_contraseña

# Si usas GITEA_AUTH_TYPE=ldap
GITEA_LDAP_USERNAME=john.doe
GITEA_LDAP_PASSWORD=tu_contraseña_ldap

# --- Parámetros Opcionales ---

# Código TOTP si la cuenta tiene 2FA (opcional)
GITEA_OTP=

# Usuario a impersonar (solo para administradores)
GITEA_SUDO_USER=

# Timeout de peticiones en ms (default: 30000)
GITEA_REQUEST_TIMEOUT=30000

# Número máximo de reintentos en errores 5xx (default: 3)
GITEA_MAX_RETRIES=3

# Para TLS self-signed en desarrollo (setear en false si es necesario)
GITEA_TLS_VERIFY=true
