# ════════════════════════════════════════════════════
# KEYCLOAK MCP — Variables de Entorno
# ════════════════════════════════════════════════════

# ────────────────────────────────────────────────────
# CONEXIÓN A KEYCLOAK
# ────────────────────────────────────────────────────
KC_HOST=https://keycloak.empresa.com
KC_ADMIN_BASE_URL=https://keycloak.empresa.com/admin/realms
KC_AUTH_REALM=master

# ────────────────────────────────────────────────────
# AUTENTICACIÓN (Client Credentials — recomendado)
# ────────────────────────────────────────────────────
KC_AUTH_GRANT_TYPE=client_credentials
KC_CLIENT_ID=keycloak-mcp-client
KC_CLIENT_SECRET=your-client-secret-here

# Alternativa: password grant
# KC_AUTH_GRANT_TYPE=password
# KC_ADMIN_USERNAME=admin
# KC_ADMIN_PASSWORD=adminpassword

# ────────────────────────────────────────────────────
# HTTP CLIENT
# ────────────────────────────────────────────────────
KC_REQUEST_TIMEOUT_MS=15000
KC_MAX_RETRY_ATTEMPTS=3
KC_RETRY_DELAY_BASE_MS=1000
KC_TLS_VERIFY=true
# KC_TLS_CA_CERT=/path/to/custom-ca.crt

# ────────────────────────────────────────────────────
# PAGINACIÓN
# ────────────────────────────────────────────────────
KC_DEFAULT_PAGE_SIZE=100
KC_MAX_PAGE_SIZE=1000
KC_AUTO_PAGINATE=true

# ────────────────────────────────────────────────────
# BASE DE DATOS POSTGRESQL (DB Inspector Module)
# ────────────────────────────────────────────────────
KC_DB_HOST=localhost
KC_DB_PORT=5432
KC_DB_NAME=keycloak
KC_DB_USERNAME=keycloak_reader
KC_DB_PASSWORD=readonly-password-here
KC_DB_SCHEMA=public
KC_DB_SSL_MODE=require
# KC_DB_SSL_CA=/path/to/db-ca.crt
KC_DB_POOL_MIN=1
KC_DB_POOL_MAX=5
KC_DB_QUERY_TIMEOUT_MS=30000
KC_DB_READ_ONLY=true

# ────────────────────────────────────────────────────
# LOGGING
# ────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_FORMAT=json

# ────────────────────────────────────────────────────
# MCP SERVER
# ────────────────────────────────────────────────────
MCP_SERVER_NAME=keycloak-mcp
MCP_SERVER_VERSION=1.0.0
MCP_TRANSPORT=stdio
