# ─────────────────────────────────────────────────
# BRUNO MCP SERVER — Variables de Entorno
# ─────────────────────────────────────────────────

# ─── COLECCIONES ──────────────────────────────────
BRUNO_COLLECTIONS_BASE_PATH=/home/user/api-collections
BRUNO_DEFAULT_COLLECTION=my-api-collection

# ─── CLI RUNNER ────────────────────────────────────
BRUNO_CLI_PATH=
BRUNO_DEFAULT_TIMEOUT_MS=10000
BRUNO_DEFAULT_DELAY_MS=0
BRUNO_BAIL_ON_FAILURE=false
BRUNO_INSECURE_SSL=false

# ─── REPORTS ───────────────────────────────────────
BRUNO_REPORTS_DIR=/tmp/bruno-mcp-reports
BRUNO_DEFAULT_REPORT_FORMAT=json
BRUNO_REPORT_RETENTION_DAYS=7

# ─── SEGURIDAD ─────────────────────────────────────
BRUNO_ALLOWED_BASE_PATHS=/home/user,/workspace,/projects
BRUNO_SCRIPTS_FILESYSTEM_ACCESS=false
BRUNO_SCRIPTS_MODULE_WHITELIST=crypto,buffer

# ─── LOGGING ───────────────────────────────────────
LOG_LEVEL=info
LOG_FORMAT=json

# ─── MCP SERVER ────────────────────────────────────
MCP_SERVER_NAME=bruno-mcp
MCP_SERVER_VERSION=1.0.0
MCP_TRANSPORT=stdio
