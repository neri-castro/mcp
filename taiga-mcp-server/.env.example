# ──────────────────────────────────────────
# TAIGA CONNECTION
# ──────────────────────────────────────────
TAIGA_HOST=https://taiga.mycompany.com
TAIGA_API_BASE_URL=https://taiga.mycompany.com/api/v1

# ──────────────────────────────────────────
# AUTENTICACIÓN (elegir una estrategia)
# ──────────────────────────────────────────
# Tipo de autenticación: "normal" o "ldap"
TAIGA_AUTH_TYPE=normal

# Credenciales del usuario de servicio del MCP
TAIGA_USERNAME=mcp-service-user
TAIGA_PASSWORD=securepassword

# ──────────────────────────────────────────
# LDAP (solo si TAIGA_AUTH_TYPE=ldap)
# La configuración LDAP se hace en el SERVIDOR Taiga, no aquí.
# El MCP solo envía type="ldap" en el body del login.
# Variables informativas:
# LDAP_SERVER=ldap://ldap.mycompany.com:389
# LDAP_SEARCH_BASE=OU=Users,DC=mycompany,DC=com
# ──────────────────────────────────────────

# ──────────────────────────────────────────
# HTTP CLIENT
# ──────────────────────────────────────────
TAIGA_REQUEST_TIMEOUT_MS=10000
TAIGA_MAX_RETRY_ATTEMPTS=3
TAIGA_RETRY_DELAY_MS=1000
TAIGA_TLS_VERIFY=true

# ──────────────────────────────────────────
# PAGINACIÓN
# ──────────────────────────────────────────
TAIGA_DEFAULT_PAGE_SIZE=100
TAIGA_MAX_PAGE_SIZE=500
TAIGA_AUTO_PAGINATE=true

# ──────────────────────────────────────────
# LOGGING
# ──────────────────────────────────────────
LOG_LEVEL=info
LOG_FORMAT=json

# ──────────────────────────────────────────
# MCP SERVER
# ──────────────────────────────────────────
MCP_SERVER_NAME=taiga-mcp
MCP_SERVER_VERSION=1.0.0
MCP_TRANSPORT=stdio
