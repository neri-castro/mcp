# ══════════════════════════════════════════════════════
# CONEXIÓN A POSTGRESQL (OBLIGATORIAS)
# ══════════════════════════════════════════════════════
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=myapp_production
PG_USER=pg_mcp_readonly
PG_PASSWORD=supersecurepassword

# ══════════════════════════════════════════════════════
# SSL / TLS
# ══════════════════════════════════════════════════════
# true | false | require | verify-full
PG_SSL=false
# Ruta al certificado CA (opcional si PG_SSL=verify-full)
PG_SSL_CA_CERT=

# ══════════════════════════════════════════════════════
# POOL DE CONEXIONES
# ══════════════════════════════════════════════════════
PG_POOL_MAX=10
PG_POOL_MIN=1
PG_POOL_IDLE_TIMEOUT_MS=30000
PG_POOL_CONNECTION_TIMEOUT_MS=5000

# ══════════════════════════════════════════════════════
# ANÁLISIS
# ══════════════════════════════════════════════════════
# Schema a analizar (default: public). Acepta '*' para todos los schemas
PG_SCHEMA=public
# Umbral en ms para considerar una query como 'lenta'
PG_SLOW_QUERY_THRESHOLD_MS=1000
# Porcentaje de bloat para disparar alerta (0-100)
PG_BLOAT_THRESHOLD_PERCENT=20
# Número máximo de consultas retornadas por pg_stat_statements
PG_STAT_STATEMENTS_LIMIT=50
# Días mínimos sin VACUUM para disparar alerta
PG_VACUUM_STALE_DAYS=7

# ══════════════════════════════════════════════════════
# PERMISOS DE ESCRITURA (DDL)
# ══════════════════════════════════════════════════════
# false = solo lectura (análisis); true = permite CREATE INDEX, VACUUM, etc.
PG_ALLOW_DDL=false
# true = permite VACUUM, ANALYZE, REINDEX
PG_ALLOW_MAINTENANCE=false

# ══════════════════════════════════════════════════════
# MCP SERVER
# ══════════════════════════════════════════════════════
MCP_SERVER_NAME=postgres-optimizer-mcp
MCP_SERVER_VERSION=1.0.0
MCP_TRANSPORT=stdio

# ══════════════════════════════════════════════════════
# LOGGING
# ══════════════════════════════════════════════════════
LOG_LEVEL=info
LOG_FORMAT=json
