# ──────────────────────────────────────────
# LARAVEL API CONNECTION
# ──────────────────────────────────────────
# URL base de la API Laravel (SIN trailing slash)
LARAVEL_API_BASE_URL=https://api.myapp.com

# Ruta del documento OpenAPI generado por Scramble
SCRAMBLE_DOCS_URL=${LARAVEL_API_BASE_URL}/docs/api.json

# Prefijo de API (para filtrar rutas en Scramble: scramble.api_path)
API_PREFIX=api

# ──────────────────────────────────────────
# AUTENTICACIÓN (detectada desde OpenAPI)
# ──────────────────────────────────────────
# Tipo: bearer | apiKey | basic | oauth2
AUTH_TYPE=bearer

# Para AUTH_TYPE=bearer o basic
AUTH_USERNAME=service_account@myapp.com
AUTH_PASSWORD=securepassword

# Para AUTH_TYPE=apiKey
AUTH_API_KEY=your_api_key_here
AUTH_API_KEY_HEADER=X-API-Key

# Para AUTH_TYPE=bearer con login endpoint Laravel
AUTH_LOGIN_ENDPOINT=/api/login
AUTH_LOGIN_USERNAME_FIELD=email
AUTH_LOGIN_PASSWORD_FIELD=password
AUTH_TOKEN_FIELD=token
AUTH_REFRESH_TOKEN_FIELD=refresh_token

# Para AUTH_TYPE=oauth2 (Client Credentials)
OAUTH_CLIENT_ID=your_client_id
OAUTH_CLIENT_SECRET=your_client_secret
OAUTH_TOKEN_URL=${LARAVEL_API_BASE_URL}/oauth/token
OAUTH_SCOPES=read:api,write:api

# ──────────────────────────────────────────
# HTTP CLIENT
# ──────────────────────────────────────────
HTTP_TIMEOUT_MS=10000
HTTP_MAX_RETRY_ATTEMPTS=3
HTTP_RETRY_DELAY_MS=1000
# false solo para desarrollo (ignorar errores SSL)
HTTP_TLS_VERIFY=true

# ──────────────────────────────────────────
# PAGINACIÓN
# ──────────────────────────────────────────
DEFAULT_PAGE_SIZE=25
MAX_PAGE_SIZE=100
# true: el MCP recupera todas las páginas automáticamente
AUTO_PAGINATE=false

# ──────────────────────────────────────────
# OPENAPI / SCRAMBLE
# ──────────────────────────────────────────
# TTL en ms del cache del documento OpenAPI (0 = sin cache)
OPENAPI_CACHE_TTL_MS=300000
# Recargar OpenAPI al iniciar siempre
OPENAPI_RELOAD_ON_START=true
# Si la API tiene múltiples versiones de Scramble (separadas por coma)
# OPENAPI_DOCS_URLS=https://api.myapp.com/docs/api.json,https://api.myapp.com/docs/v2/api.json

# ──────────────────────────────────────────
# LOGGING
# ──────────────────────────────────────────
LOG_LEVEL=info
LOG_FORMAT=json

# ──────────────────────────────────────────
# MCP SERVER
# ──────────────────────────────────────────
MCP_SERVER_NAME=laravel-scramble-mcp
MCP_SERVER_VERSION=1.0.0
MCP_TRANSPORT=stdio
